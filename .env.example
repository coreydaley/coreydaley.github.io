# Copy this file to .env and fill in your API keys.
# .env is gitignored and will never be committed.

# Anthropic API key — used by generate-post-image.py for image concept + alt text
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — used by generate-post-image.py for DALL-E 3 image generation
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

{{- /* Created by: Claude Code (Claude Sonnet 4.6) | Date: 2026-02-19T00:00:00-05:00 */ -}}
{{- $shortName := .Site.Params.manifest.shortName | default .Site.Title -}}
{{- $themeColor := .Site.Params.manifest.themeColor | default "#ffffff" -}}
{{- $bgColor := .Site.Params.manifest.backgroundColor | default "#ffffff" -}}
{
  "name": {{ .Site.Title | jsonify }},
  "short_name": {{ $shortName | jsonify }},
  "icons": [
    { "src": "/images/android-chrome-192x192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/images/android-chrome-512x512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "theme_color": {{ $themeColor | jsonify }},
  "background_color": {{ $bgColor | jsonify }},
  "display": "standalone"
}
